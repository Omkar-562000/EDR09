# EDR System Configuration
# ======================
# Copy this file to .env and update values for your deployment

# Session Management
EDR_SESSION_SECRET=your-super-secret-key-change-this-in-production
EDR_SESSION_TTL_SECONDS=43200

# Server Configuration
EDR_BACKEND_HOST=127.0.0.1
EDR_BACKEND_PORT=8000
EDR_FRONTEND_PORT=5173

# Monitoring Configuration
EDR_WATCH_PATH=backend/watched
EDR_AUTO_START_AGENT=true

# CORS Configuration
EDR_FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Security
EDR_COOKIE_SECURE=false  # Set to 'true' when using HTTPS in production

# Logging
EDR_LOG_LEVEL=INFO

# Database
EDR_DATABASE_PATH=backend/data/edr.db

# Optional: Custom Rules Path
# EDR_RULES_PATH=backend/config/rules.json

# Optional: Custom Settings Path
# EDR_SETTINGS_PATH=backend/config/settings.json
